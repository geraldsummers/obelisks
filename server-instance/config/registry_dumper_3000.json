{
  "configVersion": "1.0.0",
  "general": {
    "dumpRootFolderName": "dump",
    "runOncePerSession": true
  },
  "triggers": {
    "reloadConfigOnClientStart": true,
    "reloadConfigOnServerStart": true,
    "dumpBuiltInRegistriesOnClientStart": false,
    "dumpAssetsOnClientStart": false
  },
  "paths": {
    "registryBuiltInRoot": "registry_builtin",
    "registryRuntimeRoot": "registry_runtime",
    "rawTagsRoot": "tags",
    "expandedRuntimeTagsRoot": "registry_tags_expanded",
    "rawRecipesRoot": "recipes",
    "rawDataFoldersRoot": "data_raw",
    "rawAssetsFoldersRoot": "assets_raw",
    "unknownTagTypeFolderName": "_unknown_tag_type",
    "unknownRecipeTypeFolderName": "_unknown_recipe_type",
    "invalidJsonFolderName": "_invalid_json",
    "errorsFolderName": "_errors"
  },
  "registry": {
    "builtInRegistriesEnabled": false,
    "runtimeRegistriesEnabled": false,
    "builtInRegistryDumpFormat": "txt",
    "runtimeRegistryDumpFormat": "txt",
    "includeEntryClassNames": true
  },
  "tags": {
    "rawTagJsonsEnabled": true,
    "expandedRuntimeTagsEnabled": false,
    "prettyPrintRawTagJsons": false,
    "expandedRuntimeTagsFormat": "txt"
  },
  "recipes": {
    "rawRecipeJsonsEnabled": false,
    "prettyPrintRawRecipeJsons": false
  },
  "resources": {
